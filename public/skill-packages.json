    "cn": [
        {
            "schemaVersion": "1.0",
            "id": "builtin.cn.1700000001001",
            "version": "1.0.0",
            "name": {
                "cn": "通用问答"
            },
            "description": {
                "cn": "没有固定套路，适合日常问答、临时想法和快速处理。"
            },
            "icon": {
                "type": "emoji",
                "value": "26a1"
            },
            "category": "基础",
            "visibility": {
                "scope": "public"
            },
            "launch": {
                "type": "chat"
            },
            "instructions": {
                "type": "inline",
                "content": "你是一个面向结果的通用 AI。先理解用户目标，再给出清晰、可执行的回答。信息不足时，只追问最关键的问题；如果可以基于合理假设继续，就先说明假设并推进。避免空话和重复，优先输出结论、步骤、风险和下一步。"
            },
            "starters": [
                "帮我把这个问题想清楚，先给结论。",
                "把下面内容整理成清晰的要点。",
                "按当前信息先推进，缺少关键信息再问我。"
            ],
            "model": {
                "syncGlobalConfig": true,
                "params": {
                    "temperature": 0.4,
                    "max_tokens": 4000,
                    "presence_penalty": 0,
                    "frequency_penalty": 0,
                    "sendMemory": true,
                    "historyMessageCount": 12,
                    "compressMessageLengthThreshold": 2000
                }
            },
            "tools": [],
            "toolServers": [],
            "ui": {
                "sessionToolbar": {
                    "settings": true,
                    "theme": true,
                    "promptHints": true,
                    "skillSwitcher": true,
                    "clearContext": true,
                    "modelSelector": true,
                    "imageUpload": true,
                    "imageParams": false,
                    "plugins": true,
                    "tools": true,
                    "shortcutKeys": true,
                    "realtime": false
                }
            },
            "permissions": {
                "network": false,
                "filesystem": false,
                "wallet": false,
                "externalTools": []
            },
            "compatibility": {
                "appVersion": ">=0.1.0"
            },
            "release": {
                "status": "published",
                "review": "approved"
            }
        },
        {
            "schemaVersion": "1.0",
            "id": "builtin.cn.1700000001002",
            "version": "1.0.0",
            "name": {
                "cn": "网页调研"
            },
            "description": {
                "cn": "搜索网页、抓取来源、对比总结，适合需要最新资料的问题。"
            },
            "icon": {
                "type": "emoji",
                "value": "1f50d"
            },
            "category": "研究",
            "visibility": {
                "scope": "public"
            },
            "launch": {
                "type": "chat"
            },
            "instructions": {
                "type": "inline",
                "content": "你正在执行网页研究任务。需要最新信息、公开网页资料、技术调研或产品对比时，优先使用网页搜索工具找来源，再用网页抓取工具读取原文。不要把搜索结果页当作正文来源。回答时先给结论，再列关键证据、差异、不确定点和来源链接。工具不可用、来源不足或抓取失败时，要直接说明，不要捏造来源。"
            },
            "starters": [
                "请先搜索这个主题，再抓取最相关的两个来源并对比总结。",
                "围绕这个问题做多来源调研，输出结论、证据和不确定点。",
                "帮我查找最新资料，并附上来源链接。"
            ],
            "model": {
                "syncGlobalConfig": true,
                "params": {
                    "temperature": 0.25,
                    "max_tokens": 6000,
                    "presence_penalty": 0,
                    "frequency_penalty": 0,
                    "sendMemory": true,
                    "historyMessageCount": 10,
                    "compressMessageLengthThreshold": 2000,
                    "responsesMode": "stateful"
                }
            },
            "tools": [],
            "toolServers": [
                {
                    "id": "brave-search",
                    "name": "brave-search",
                    "transport": "stdio",
                    "required": true
                },
                {
                    "id": "fetch",
                    "name": "fetch",
                    "transport": "stdio",
                    "required": true
                }
            ],
            "ui": {
                "sessionToolbar": {
                    "settings": true,
                    "theme": true,
                    "promptHints": true,
                    "skillSwitcher": true,
                    "clearContext": true,
                    "modelSelector": true,
                    "imageUpload": true,
                    "imageParams": false,
                    "plugins": false,
                    "tools": true,
                    "shortcutKeys": true,
                    "realtime": false
                }
            },
            "permissions": {
                "network": false,
                "filesystem": false,
                "wallet": false,
                "externalTools": [
                    "brave-search",
                    "fetch"
                ]
            },
            "compatibility": {
                "appVersion": ">=0.1.0"
            },
            "release": {
                "status": "published",
                "review": "approved"
            }
        },
        {
            "schemaVersion": "1.0",
            "id": "builtin.cn.1700000001003",
            "version": "1.0.0",
            "name": {
                "cn": "阅读总结"
            },
            "description": {
                "cn": "读取网页、文档或长文本，提炼摘要、结构和行动项。"
            },
            "icon": {
                "type": "emoji",
                "value": "1f4c4"
            },
            "category": "阅读",
            "visibility": {
                "scope": "public"
            },
            "launch": {
                "type": "chat"
            },
            "instructions": {
                "type": "inline",
                "content": "你正在执行阅读总结任务。优先保留原文事实、结构和关键结论，区分原文观点与自己的分析。默认输出：一句话摘要、关键要点、重要细节、可执行事项、仍需确认的问题。不要擅自补充原文没有的信息；如果材料来自网页，尽量附来源链接。"
            },
            "starters": [
                "抓取这个网页并用中文总结重点。",
                "阅读下面这段长文，提炼摘要、关键结论和待办事项。",
                "把这份材料整理成适合汇报的结构。"
            ],
            "model": {
