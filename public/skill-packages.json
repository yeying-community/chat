        {
            "schemaVersion": "1.0",
            "id": "builtin.en.1700000002002",
            "version": "1.0.0",
            "name": {
                "en": "Web Research"
            },
            "description": {
                "en": "Search the web, fetch source pages, compare findings, and cite links."
            },
            "icon": {
                "type": "emoji",
                "value": "1f50d"
            },
            "category": "Research",
            "visibility": {
                "scope": "public"
            },
            "launch": {
                "type": "chat"
            },
            "instructions": {
                "type": "inline",
                "content": "You are doing a web research task. For current information, public web materials, technical research, or product comparisons, prefer a web search tool to discover sources, then a fetch tool to read source pages. Do not treat search result pages as source documents. Start with the conclusion, then list key evidence, differences, uncertainty, and source links. If tools are unavailable, sources are insufficient, or fetching fails, say so directly and do not invent sources."
            },
            "starters": [
                "Search this topic first, fetch the two most relevant sources, and compare them.",
                "Research this question across multiple sources and separate conclusions from evidence.",
                "Find current information and include source links."
            ],
            "model": {
                "syncGlobalConfig": true,
                "params": {
                    "temperature": 0.25,
                    "max_tokens": 6000,
                    "presence_penalty": 0,
                    "frequency_penalty": 0,
                    "sendMemory": true,
                    "historyMessageCount": 10,
                    "compressMessageLengthThreshold": 2000,
                    "responsesMode": "stateful"
                }
            },
            "tools": [],
            "toolServers": [
                {
                    "id": "brave-search",
                    "name": "brave-search",
                    "transport": "stdio",
                    "required": true
                },
                {
                    "id": "fetch",
                    "name": "fetch",
                    "transport": "stdio",
                    "required": true
                }
            ],
            "ui": {
                "sessionToolbar": {
                    "settings": true,
                    "theme": true,
                    "promptHints": true,
                    "skillSwitcher": true,
                    "clearContext": true,
                    "modelSelector": true,
                    "imageUpload": true,
                    "imageParams": false,
                    "plugins": false,
                    "tools": true,
                    "shortcutKeys": true,
                    "realtime": false
                }
            },
            "permissions": {
