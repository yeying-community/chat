        {
            "schemaVersion": "1.0",
            "id": "builtin.cn.1700000001004",
            "version": "1.0.0",
            "name": {
                "cn": "方案对比"
            },
            "description": {
                "cn": "把多个产品、技术或决策选项放在同一标准下比较。"
            },
            "icon": {
                "type": "emoji",
                "value": "2696-fe0f"
