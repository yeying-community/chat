# Chat 运行期配置模板
#
# 这个文件只用于部署期和服务运行期变量。
# 发包完成后，仍然可以继续修改这个文件。
#
# 运行规则：
# 1. 服务端运行期配置
#    - Node 服务启动时从 `.env` 读取
#    - 修改后需要重启服务
# 2. 前端公开运行期配置
#    - 也在 Node 服务启动时从 `.env` 读取
#    - 会通过 `meta[name="runtime-config"]` 和 `/api/config` 下发到浏览器
#    - 修改后需要重启服务，并刷新页面
#
# 构建/发包变量已经移动到 `.env.build.template`。
#
# 本文件中的布尔开关统一推荐使用：
# - `0`：关闭
# - `1`：开启
# 同时兼容 `true` / `false` 写法，但推荐统一使用 `0` / `1`。
#
# 填写建议：
# - 只填写你当前实际会用到的 provider 配置
# - 不要把没用到的密钥也一起塞进生产环境
# - 私钥、Token、API Key 都属于敏感信息，不要提交到仓库

################################################################################
# 基础上游配置
# 服务端运行期配置 - 私有 / 仅后端使用
# 生效方式：需要重启服务
# 浏览器是否可见：否
################################################################################

# OpenAI 或 OpenAI 兼容接口的 API Key。
# - 支持多个 key，用英文逗号分隔
# - 服务端会随机取一个 key 使用
# - 如果你只接 OpenAI 兼容网关，这通常是最先要填的一项
OPENAI_API_KEY=

# OpenAI 或 OpenAI 兼容接口的基础地址。
# 示例：
# - 官方 OpenAI: https://api.openai.com
# - 自建兼容网关: https://your-gateway.example.com
# 留空时，按各 provider 自身逻辑处理。
BASE_URL=

# 可选：OpenAI 组织 ID。
# 只有在你的上游明确要求传这个头时才需要填写。
OPENAI_ORG_ID=

# 可选：访问码。
# - 用英文逗号分隔可配置多个访问码
# - 原始值不会暴露到前端
# - 前端只能看到当前服务“是否要求访问码”
CODE=

# 可选：代理地址。
# 主要给某些部署环境下的服务端代理链路使用。
PROXY_URL=

################################################################################
# Provider 配置
# 服务端运行期配置 - 私有 / 仅后端使用
# 生效方式：需要重启服务
# 浏览器是否可见：否
################################################################################

# Stability 配置
STABILITY_URL=
STABILITY_API_KEY=

# Azure OpenAI 配置
# `AZURE_URL` 通常形如：
# https://{resource}.openai.azure.com/openai/deployments/{deployment}
AZURE_URL=
AZURE_API_KEY=
AZURE_API_VERSION=

# Google / Gemini 配置
GOOGLE_API_KEY=
GOOGLE_URL=

# Anthropic 配置
ANTHROPIC_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_API_VERSION=

# 百度千帆配置
BAIDU_URL=
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# 火山引擎配置
VOLCENGINE_URL=
VOLCENGINE_API_KEY=

# 阿里云配置
ALIBABA_URL=
ALIBABA_API_KEY=

# 腾讯云配置
TENCENT_URL=
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=

# Moonshot 配置
MOONSHOT_URL=
MOONSHOT_API_KEY=

# 讯飞星火配置
IFLYTEK_URL=
IFLYTEK_API_KEY=
IFLYTEK_API_SECRET=

# DeepSeek 配置
DEEPSEEK_URL=
DEEPSEEK_API_KEY=

# xAI 配置
XAI_URL=
XAI_API_KEY=

# 智谱 ChatGLM 配置
CHATGLM_URL=
CHATGLM_API_KEY=

# SiliconFlow 配置
SILICONFLOW_URL=
SILICONFLOW_API_KEY=

# 302.AI 配置
AI302_URL=
AI302_API_KEY=

################################################################################
# 统计 / 基础设施配置
# 服务端运行期配置 - 私有 / 仅后端使用
# 生效方式：需要重启服务
# 浏览器是否可见：否
################################################################################

# Google Tag Manager 容器 ID。
# 只有你确实接了 GTM 才需要填写。
GTM_ID=

# Google Analytics ID。
# 只有你确实接了 GA 才需要填写。
GA_ID=

# Cloudflare KV 配置。
# 只有你启用了对应的 KV 能力时才需要填写。
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_KV_NAMESPACE_ID=
CLOUDFLARE_KV_API_KEY=
CLOUDFLARE_KV_TTL=

# 是否允许 `/api/webdav/[...path]` 访问本地 WebDAV 地址。
# - `0`：仅允许白名单地址
# - `1`：额外允许 127.0.0.1 / localhost / ::1
# 默认建议保持 `0`。
ALLOW_LOCAL_WEBDAV=0

################################################################################
# 前端公开运行期配置
# 浏览器可见
# 生效方式：重启服务 + 刷新页面
################################################################################

# 默认输入模板。
# 用于在请求发送前预处理用户输入。
# 留空时使用项目内置默认模板。
DEFAULT_INPUT_TEMPLATE=

# 是否隐藏用户手动填写 API Key 的界面。
# - `0`：显示
# - `1`：隐藏
HIDE_USER_API_KEY=0

# 是否禁用 GPT-4 类模型。
# - `0`：不禁用
# - `1`：禁用
DISABLE_GPT4=0

# 是否允许前端查询余额。
# 注意：这个变量是“正向开关”。
# - `0`：不允许
# - `1`：允许
ENABLE_BALANCE_QUERY=0

# 是否禁用通过 URL 快速导入配置的能力。
# - `0`：不禁用
# - `1`：禁用
DISABLE_FAST_LINK=0

# 自定义模型列表。
# 用于控制前端可见模型集合。
# 具体格式保持与现有部署约定一致；不需要时留空。
CUSTOM_MODELS=

# 新建会话默认模型。
# 如果填写的模型被 `DISABLE_GPT4=1` 禁掉，服务端会自动回退。
DEFAULT_MODEL=

# 视觉模型列表。
# 用于声明哪些模型支持图像能力。
VISION_MODELS=

# 是否启用工具运行时。
# - `0`：不启用
# - `1`：启用
# 启用后还需要保证运行环境允许启动外部命令，并能读写 `data/tool_config.json`。
ENABLE_TOOLS=0

# Router 后端地址。
# 浏览器侧调用 Router 能力时使用这个地址。
# 留空时服务端会回退到内置默认值 `http://127.0.0.1:3011`。
ROUTER_BACKEND_URL=http://127.0.0.1:3011

# Router 管理中心地址。
# Chat 在“选择令牌 / 充值 / 续费”引导场景下会跳到这个地址。
# 留空时默认使用 `https://router.yeying.pub`。
ROUTER_PORTAL_URL=https://router.yeying.pub

# Router 令牌页地址。
# 可单独指向管理中心中的令牌列表页；未填写时继承 `ROUTER_PORTAL_URL`。
ROUTER_PORTAL_TOKEN_URL=

# Router 充值页地址。
# 可单独指向管理中心中的充值页；未填写时继承 `ROUTER_PORTAL_TOKEN_URL`。
ROUTER_PORTAL_RECHARGE_URL=

# WebDAV 后端基础地址。
# 浏览器侧云同步 / WebDAV 访问会使用它。
# 如果这个值本身已经带 path，服务端会尽量自动拆成 `base + prefix`。
WEBDAV_BACKEND_BASE_URL=http://127.0.0.1:6065

# WebDAV 路径前缀。
# 默认是 `/dav`。
WEBDAV_BACKEND_PREFIX=/dav

# 中心化 UCAN 认证服务地址。
# 浏览器发起中心化授权时会访问这个地址。
CENTRAL_UCAN_AUTH_BASE_URL=http://127.0.0.1:8100

# 中心化 UCAN 应用 ID。
# 只有你启用了中心化 UCAN 登录链路时才需要填写。
CENTRAL_UCAN_APP_ID=

# 登录模式：
# - `auto`：自动选择
# - `wallet`：强制钱包登录
# - `central`：强制中心化授权登录
UCAN_LOGIN_FORCE_MODE=auto

# Marketplace 清单地址。
# 默认不需要填写：应用会按 `GitHub raw -> jsDelivr CDN -> 内置快照` 的顺序加载。
# 本地开发新 skill/tool 时推荐使用 `npm run dev:marketplace`，脚本会自动注入这两个变量。
# 如果你要接私有 marketplace，可以在这里覆盖为自己的清单地址。
MARKETPLACE_SKILL_PACKAGES_URL=
MARKETPLACE_TOOL_PACKAGES_URL=

################################################################################
# 不属于应用配置层的进程 / 部署变量
# 生效方式取决于你的进程管理方式
################################################################################

# `npm run start` 或部署脚本常用的运行端口。
PORT=3020
