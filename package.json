{
  "name": "chat",
  "private": false,
  "license": "mit",
  "scripts": {
    "mask": "npx tsx app/masks/build.ts",
    "mask:watch": "npx watch \"npm run mask\" app/masks",
    "dev": "concurrently -r \"npm run mask:watch\" \"next dev --webpack -p 3020\"",
    "build": "npm run mask && cross-env BUILD_MODE=standalone next build --webpack",
    "start": "PORT=3020 node .next/standalone/server.js",
    "lint": "eslint .",
    "export": "node ./scripts/export-app.mjs",
    "export:dev": "concurrently -r \"npm run mask:watch\"  \"cross-env BUILD_MODE=export BUILD_APP=1 next dev --webpack -p 3020\"",
    "app:dev": "concurrently -r \"npm run mask:watch\" \"npx tauri dev\"",
    "app:build": "node ./scripts/tauri-build-app.mjs",
    "app:build:release": "node ./scripts/tauri-build-app.mjs --release-updater",
    "prompts": "node ./scripts/fetch-prompts.mjs",
    "prepare": "husky",
    "proxy-dev": "sh ./scripts/init-proxy.sh && proxychains -f ./scripts/proxychains.conf npm run dev",
    "test": "node --no-warnings --experimental-vm-modules ./node_modules/.bin/jest --watch",
    "test:ci": "node --no-warnings --experimental-vm-modules ./node_modules/.bin/jest --ci"
  },
  "dependencies": {
    "@fortaine/fetch-event-source": "^3.0.6",
    "@hello-pangea/dnd": "^18.0.1",
    "@jest/globals": "^30.4.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@next/third-parties": "^16.1.6",
    "@svgr/webpack": "^8.1.0",
    "@tauri-apps/plugin-clipboard-manager": "2.3.2",
    "@tauri-apps/plugin-dialog": "2.6.0",
    "@tauri-apps/plugin-fs": "2.4.5",
    "@tauri-apps/plugin-notification": "2.3.3",
    "@tauri-apps/plugin-updater": "2.9.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^1.3.1",
    "@yeying-community/web3-bs": "1.0.8",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "csstype": "^3.2.3",
    "emoji-picker-react": "^4.19.1",
    "fuse.js": "^7.0.0",
    "heic2any": "^0.0.4",
    "html-to-image": "^1.11.11",
    "idb-keyval": "^6.2.1",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.45",
    "lodash": "4.17.21",
    "lodash-es": "^4.17.21",
    "markdown-to-txt": "^2.0.1",
    "mermaid": "^11.12.2",
    "nanoid": "^5.1.9",
    "next": "^16.1.6",
    "openapi-client-axios": "^7.5.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "rt-client": "https://github.com/Azure-Samples/aoai-realtime-audio-sdk/releases/download/js/v0.5.0/rt-client-0.5.0.tgz",
    "sass": "^1.97.2",
    "sonner": "^2.0.7",
    "spark-md5": "^3.0.2",
    "unified": "^11.0.5",
    "use-debounce": "^9.0.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tauri-apps/api": "2.9.1",
    "@tauri-apps/cli": "2.9.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-katex": "^3.0.4",
    "@types/spark-md5": "^3.0.4",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.59.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.2",
    "tsx": "^4.21.0",
    "typescript": "6.0.3",
    "watch": "^1.0.2",
    "webpack": "^5.106.2"
  },
  "overrides": {
    "test-exclude": "^7.0.1"
  },
  "packageManager": "npm@11.6.2"
}
